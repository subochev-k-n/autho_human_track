# Настройки трекера автогуманиста
# Скопируйте в .env и измените под себя

# SECRET_KEY: сгенерируйте свой! Можно через: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-this-secret-key-in-production

# Часовой пояс (блокировка 18:00 считается по нему)
TIMEZONE=Europe/Moscow

# Час блокировки (до скольки нельзя заполнять)
BLOCK_HOUR=18

# Режим тестирования (снимает блокировку по времени)
# TEST_MODE=true
# TEST_DATE=2026-07-11
# TEST_HOUR=20
